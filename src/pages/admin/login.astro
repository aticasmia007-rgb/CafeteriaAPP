---
export const prerender = false;

// If already logged in, redirect to admin
const sessionCookie = Astro.cookies.get("admin_session");
if (sessionCookie?.value === "authenticated") {
  return Astro.redirect("/admin");
}

// Handle POST login
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const pin = formData.get("pin");
  // Mock auth: PIN "1234" grants access
  if (pin === "1234") {
    Astro.cookies.set("admin_session", "authenticated", {
      path: "/",
      httpOnly: true,
      sameSite: "lax",
      maxAge: 60 * 60 * 8, // 8 hours
    });
    return Astro.redirect("/admin");
  }
}

import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout>
  <div class="login-page">
    <div class="login-card">
      <div class="login-logo">🍽️</div>
      <h1 class="login-title">Panel de Administración</h1>
      <p class="login-subtitle">Cafetería IES Pío Baroja</p>

      <form method="POST" class="login-form">
        <label class="login-label" for="pin">PIN de acceso</label>
        <input
          class="login-input"
          type="password"
          id="pin"
          name="pin"
          placeholder="••••"
          maxlength="4"
          inputmode="numeric"
          pattern="[0-9]*"
          required
          autofocus
        />
        <button type="submit" class="login-btn">Entrar</button>
        <p class="login-hint">PIN de prueba: <strong>1234</strong></p>
      </form>
    </div>
  </div>
</AdminLayout>

<style>
  .login-page {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .login-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: 48px 40px;
    max-width: 380px;
    width: 100%;
    text-align: center;
  }

  .login-logo {
    font-size: 56px;
    margin-bottom: 16px;
  }

  .login-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--color-primary-dark);
    margin-bottom: 4px;
  }

  .login-subtitle {
    font-size: 14px;
    color: var(--color-gray-500);
    margin-bottom: 32px;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .login-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-gray-600);
    text-align: left;
  }

  .login-input {
    width: 100%;
    padding: 14px 16px;
    font-size: 24px;
    font-family: inherit;
    text-align: center;
    letter-spacing: 12px;
    border: 2px solid var(--color-gray-200);
    border-radius: var(--radius-md);
    background: var(--color-white);
    color: var(--color-gray-800);
    outline: none;
    transition: border-color 0.2s;
  }

  .login-input:focus {
    border-color: var(--color-primary);
  }

  .login-btn {
    margin-top: 8px;
    padding: 14px;
    font-size: 16px;
    font-weight: 600;
    font-family: inherit;
    color: var(--color-white);
    background: var(--color-primary);
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: background 0.2s;
  }

  .login-btn:hover {
    background: var(--color-primary-dark);
  }

  .login-hint {
    margin-top: 8px;
    font-size: 12px;
    color: var(--color-gray-400);
  }
</style>

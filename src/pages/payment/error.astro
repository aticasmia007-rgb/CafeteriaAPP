---
import Layout from "../../layouts/Layout.astro";
---

<Layout>
  <div style="display:flex;align-items:center;justify-content:center;min-height:100dvh;background:var(--color-bg,#f5f0e8);font-family:'DM Sans',sans-serif;padding:24px;">
    <div style="text-align:center;max-width:360px;width:100%;">
      <div style="font-size:56px;margin-bottom:16px;">❌</div>
      <h1 style="font-size:22px;font-weight:700;color:#c0392b;margin:0 0 8px;">Pago no completado</h1>
      <p style="font-size:15px;color:#6b7280;margin:0 0 24px;">El pago ha sido cancelado o ha ocurrido un error. No se ha realizado ningún cargo.</p>
      <a
        href="/"
        style="display:inline-block;padding:12px 28px;background:#2f5d3a;color:#fff;border-radius:12px;font-weight:600;font-size:15px;text-decoration:none;"
      >
        Volver a la app
      </a>
    </div>
  </div>
</Layout>
